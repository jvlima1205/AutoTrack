<MudDialog TitleClass="bg-warning text-white" ContentClass="py-5">
    <TitleContent>
        <h3>Editar Véiculo do Cliente</h3>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@form">
            <MudGrid Spacing="2">

                <MudItem xs="12">
                    <MudTextField Variant="Variant.Outlined" For="@(() => form.Name)" Label="Nome" @bind-Value="form.Name"
                                  ReadOnly="true" />
                  
                </MudItem>

                <MudItem xs="6">
                    <MudSelect T="int" Variant="Variant.Outlined" Label="Marca" Value="@_idBrand" ValueChanged="OnChange"
                               Required="true" RequiredError="Modelo obrigatório">
                        @foreach (tVehicleBrand brand in _brands)
                        {
                            <MudSelectItem Value="brand.IdVehicleBrand">@brand.Brand</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>

                <MudItem xs="6">
                    <MudSelect T="int" Variant="Variant.Outlined" Label="Modelo" @bind-Value="@_idVehicle" Disabled="!_brandSelect"
                               Required="true" RequiredError="Nome obrigatório">
                        @if (_vehicles.Any())
                            @foreach (tVehicle vehicle in _vehicles)
                            {
                                <MudSelectItem Value="vehicle.IdVehicle">@vehicle.Vehicle</MudSelectItem>
                            }
                    </MudSelect>
                </MudItem>


                <MudItem xs="12">
                    <MudTextField Variant="Variant.Outlined" For="@(() => form.Plate)" Label="Placa" @bind-Value="form.Plate"
                                  Required="true" RequiredError="Placa obrigatória" />
                </MudItem>


                <MudItem xs="6">
                    <MudNumericField Variant="Variant.Outlined" For="@(() => form.YearManufacture)" Label="Ano de Fabricação"
                                     @bind-Value="form.YearManufacture" Required="true" RequiredError="Ano de Fabricação obrigatório" />
                </MudItem>

                <MudItem xs="6">
                    <MudNumericField Variant="Variant.Outlined" For="@(() => form.YearModel)" Label="Ano do Modelo"
                                     @bind-Value="form.YearModel" Required="true" RequiredError="Ano do Modelo obrigatório" />
                </MudItem>

            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Submit">Salvar Alterações</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public vwVehicleClient form { get; set; } = new();

    private int _idBrand = 0;
    private List<tVehicleBrand> _brands { get; set; } = [];

    private bool _brandSelect = false;

    private int _idVehicle = 0;
    private List<tVehicle> _vehicles { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        _brands = await DBAutoTrackContext.tVehicleBrand.ToListAsync();
        if (!_brands.Any()) return;

        _idBrand = _brands.FirstOrDefault(x => x.IdVehicleBrand == form.IdVehicleBrand)!.IdVehicleBrand;
        await OnChange(_idBrand);
    }

    private async Task OnChange(int idBrand)
    {
        _idBrand = idBrand;
        _brandSelect = true;

        _vehicles = await DBAutoTrackContext.tVehicle.Where(x => x.IdVehicleBrand == idBrand).ToListAsync();
        if (_vehicles.Any())
            _idVehicle = _vehicles.First().IdVehicle;
 
        StateHasChanged();
    }

    private void Submit()
    {
        tVehicleClient vehicleClient = DBAutoTrackContext.tVehicleClient.Find(form.IdVehicleClient)!;
        if (vehicleClient is null) Cancel();

        if (vehicleClient!.IdVehicle != _idVehicle)
            vehicleClient.IdVehicle = _idVehicle;

        if (vehicleClient.Plate != form.Plate)
            vehicleClient.Plate = form.Plate;

        if (vehicleClient.YearManufacture != form.YearManufacture)
            vehicleClient.YearManufacture = form.YearManufacture;

        if (vehicleClient.YearModel != form.YearModel)
            vehicleClient.YearModel = form.YearModel;
       
        DBAutoTrackContext.SaveChanges();

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}