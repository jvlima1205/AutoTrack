@page "/VehicleClient/Home/{IdClient:int}"
@rendermode InteractiveServer

<section class="d-flex flex-column gap-3">

    <div class="d-flex flex-column gap-3">
        <div>
            <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.KeyboardBackspace" Color="Color.Dark" Href="Client/Home">Voltar</MudButton>
        </div>
        <h3>Lista de Veículos do Cliente: <ins>@_client!.Name</ins></h3>
    </div>

    <div>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Add">Adicionar Veículo</MudButton>
    </div>

    <div>
        <MudTable FixedHeader="true"
                  FixedFooter="true"
                  Class="p-2"
                  Items="@mudtable.Data"
                  Filter="@mudtable.Function"
                  Height="@mudtable.Height"
                  RowsPerPage="@mudtable.RowsPerPage" @bind-SelectedItem="mudtable.SelectedItem">
            <ColGroup>
                <col />
                <col />
                <col />
                <col />
                <col />
                <col style="width: 20%;" />
            </ColGroup>
            <ToolBarContent>
                <MudText Typo="Typo.h6">Veículos Cadastrados</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="mudtable.SearchString"
                              Placeholder="@mudtable.Placeholder"
                              Adornment="Adornment.Start"
                              Variant="Variant.Outlined"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium">
                </MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Marca</MudTh>
                <MudTh>Veículo</MudTh>
                <MudTh>Placa</MudTh>
                <MudTh>Ano de Fabricação</MudTh>
                <MudTh>Ano do Modelo</MudTh>
                <MudTh>Ações</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Brand</MudTd>
                <MudTd>@context.Vehicle</MudTd>
                <MudTd>@context.Plate</MudTd>
                <MudTd>@context.YearManufacture</MudTd>
                <MudTd>@context.YearModel</MudTd>
                <MudTd>
                    <MudButton OnClick="@(() => Edit(context))" Variant="Variant.Outlined" Color="Color.Warning">Editar</MudButton>
                    <MudButton OnClick="@(() => Delete(context))" Variant="Variant.Outlined" Color="Color.Error">Deletar</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

</section>



@code {

    [Parameter]
    public int IdClient { get; set; }

    private tClient? _client { get; set; } = new();

    private vwVehicleClient? _vehicleClient { get; set; } = new();

    private MudtableFunction<vwVehicleClient> mudtable = new();


    protected override async Task OnInitializedAsync()
    {
        try
        {
            _client = await DBAutoTrackContext.tClient.FindAsync(IdClient);

            _vehicleClient = await DBAutoTrackContext.vwVehicleClient.FirstOrDefaultAsync(x => x.IdClient == IdClient);

            if (_vehicleClient is null)
            {
                _vehicleClient = new vwVehicleClient()
                {
                    IdClient = _client!.IdClient,
                    Name = _client.Name,
                    Address = _client.Address,
                    HouseNumber = _client.HouseNumber,
                    District = _client.District,
                    City = _client.City,
                    State = _client.State,
                    CEP = _client.CEP,
                    Contact = _client.Contact,
                    ContactAux = _client.ContactAux,
                };
                return;
            }

            await UpdateData();
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

    private async Task UpdateData()
    {
        try
        {
            mudtable.Data = await DBAutoTrackContext.vwVehicleClient.Where(x => x.IdClient == _client!.IdClient).ToListAsync();
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

    private async Task Add()
    {
        try
        {
            var parameters = new DialogParameters<VehicleClientAdd>
            {
                { x => x.form, _vehicleClient }
            };

            var dialog = await Dialog.ShowAsync<VehicleClientAdd>("AddVehicleClient", parameters);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                await UpdateData();
                Snack.SuccessAdd();
            }
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

    private async Task Edit(vwVehicleClient vehicle)
    {
        try
        {
            var parameters = new DialogParameters<VehicleClientEdit>
            {
                { x => x.form, vehicle }
            };

            var dialog = await Dialog.ShowAsync<VehicleClientEdit>("EditVehicleClient", parameters);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                await UpdateData();
                Snack.SuccessEdit();
            }
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

    private async Task Delete(vwVehicleClient vehicle)
    {
        try
        {
            var parameters = new DialogParameters<VehicleClientDelete>
            {
                { x => x.form, vehicle }
            };

            var dialog = await Dialog.ShowAsync<VehicleClientDelete>("DeleteVehicleClient", parameters);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                await UpdateData();
                Snack.SuccessDelete();
            }
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

}
