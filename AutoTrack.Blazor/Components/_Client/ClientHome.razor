@page "/Client/Home"
@rendermode InteractiveServer

<section class="d-flex flex-column gap-3">

    <h3>Lista de Clientes</h3>

    <div>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Add">Adicionar Cliente</MudButton>
    </div>

    <div>
        <MudTable FixedHeader="true"
                  FixedFooter="true"
                  Class="p-2"
                  Items="@mudtable.Data"
                  Filter="@mudtable.Function"
                  Height="@mudtable.Height"
                  RowsPerPage="@mudtable.RowsPerPage" @bind-SelectedItem="mudtable.SelectedItem">
            <ColGroup>
                <col />
                <col />
                <col />
                <col style="width: 20%;" />
            </ColGroup>
            <ToolBarContent>
                <MudText Typo="Typo.h6">Clientes Cadastrados</MudText>
                <MudSpacer />
                <MudTextField @bind-Value="mudtable.SearchString"
                              Placeholder="@mudtable.Placeholder"
                              Adornment="Adornment.Start"
                              Variant="Variant.Outlined"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              IconSize="Size.Medium">
                </MudTextField>
            </ToolBarContent>
            <HeaderContent>
                <MudTh>Nome</MudTh>
                <MudTh>Contato</MudTh>
                <MudTh>Contato Auxiliar</MudTh>
                <MudTh>Ações</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd>@context.Name</MudTd>
                <MudTd>@context.Contact</MudTd>
                <MudTd>@context.ContactAux</MudTd>
                <MudTd>
                    <MudButton Href="@($"VehicleClient/Home/{context.IdClient}")" Variant="Variant.Outlined" Color="Color.Info">Veículos</MudButton>
                    <MudButton OnClick="@(() => Edit(context))" Variant="Variant.Outlined" Color="Color.Warning">Editar</MudButton>
                    <MudButton OnClick="@(() => Delete(context))" Variant="Variant.Outlined" Color="Color.Error">Deletar</MudButton>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </div>

</section>



@code {
    private MudtableFunction<tClient> mudtable = new();


    protected override async Task OnInitializedAsync()
    {
        await UpdateData();
    }

    private async Task UpdateData()
    {
        try
        {
            mudtable.Data = await DBAutoTrackContext.tClient.ToListAsync();
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

    private async Task Add()
    {
        try
        {
            var dialog = await Dialog.ShowAsync<ClientAdd>("AddClient");
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                await UpdateData();
                Snack.SuccessAdd();
            }
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

    private async Task Edit(tClient client)
    {
        try
        {
            var parameters = new DialogParameters<ClientEdit>
            {
                { x => x.form, client }
            };

            var dialog = await Dialog.ShowAsync<ClientEdit>("EditClient", parameters);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                await UpdateData();
                Snack.SuccessEdit();
            }
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

    private async Task Delete(tClient client)
    {
        try
        {
            var parameters = new DialogParameters<ClientDelete>
            {
                { x => x.form, client }
            };

            var dialog = await Dialog.ShowAsync<ClientDelete>("DeleteClient", parameters);
            var result = await dialog.Result;

            if (!result!.Canceled)
            {
                await UpdateData();
                Snack.SuccessDelete();
            }
        }
        catch (Exception ex)
        {
            Redirect.Error(ex);
        }
    }

}
