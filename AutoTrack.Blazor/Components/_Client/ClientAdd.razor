<MudDialog TitleClass="bg-success text-white" ContentClass="py-5">
    <TitleContent>
        <h3>Adicionar Cliente</h3>
    </TitleContent>
    <DialogContent>
        <MudForm Model="@form" Spacing="2" Class="d-flex flex-column">

            <div class="d-flex flex-row">
                <MudTextField Variant="Variant.Outlined" For="@(() => form.Name)" Label="Nome" @bind-Value="form.Name" Required="true" RequiredError="Nome obrigatório" />
            </div>

            <div class="d-flex flex-row gap-3">
                <MudTextField Variant="Variant.Outlined" For="@(() => form.Address)" Label="Endereço" @bind-Value="form.Address" Required="true" RequiredError="Endereço obrigatório" />
                <MudTextField Variant="Variant.Outlined" For="@(() => form.HouseNumber)" Label="N°" @bind-Value="form.HouseNumber" Required="true" RequiredError="Número da casa obrigatório" />
                <MudTextField Variant="Variant.Outlined" For="@(() => form.District)" Label="Bairro" @bind-Value="form.District" Required="true" RequiredError="Bairro obrigatório" />
            </div>

            <div class="d-flex flex-row gap-3">
                <MudTextField Variant="Variant.Outlined" For="@(() => form.City)" Label="Cidade" @bind-Value="form.City" Required="true" RequiredError="Cidade obrigatório" />
                <MudTextField Variant="Variant.Outlined" For="@(() => form.State)" Label="Estado" @bind-Value="form.State" Required="true" RequiredError="Estado obrigatório" />
                <MudTextField Variant="Variant.Outlined" For="@(() => form.CEP)" Label="CEP" @bind-Value="form.CEP" />
            </div>

            <div class="d-flex flex-row gap-3">
                <MudTextField Variant="Variant.Outlined" For="@(() => form.Contact)" Label="Contato" @bind-Value="form.Contact" Required="true" RequiredError="Marca obrigatória" />
                <MudTextField Variant="Variant.Outlined" For="@(() => form.ContactAux)" Label="Contato Auxiliar" @bind-Value="form.ContactAux" />
            </div>

        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancelar</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Success" OnClick="Submit">Adicionar</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    public tClient form { get; set; } = new();

    private void Submit()
    {
        tClient client = new()
        {
            Name = form.Name,
            Address = form.Address,
            HouseNumber = form.HouseNumber,
            District = form.District,
            City = form.City,
            State = form.State,
            CEP = form.CEP,
            Contact = form.Contact,
            ContactAux = form.ContactAux,
        };

        DBAutoTrackContext.tClient.Add(client);
        DBAutoTrackContext.SaveChanges();

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}