<MudDialog>
    <TitleContent>
        Adicionar Ordem de Serviço
    </TitleContent>
    <DialogContent>
        <MudForm Model="@model" Spacing="2">
            <MudTextField For="@(() => model.Number)" Label="Parameter Label" />

            <MudSelect @bind-Value="@_client">
                @foreach (tClient client in _clients)
                {
                    <MudSelectItem Value="client.IdClient">@client.Name</MudSelectItem>
                }
            </MudSelect>

            <MudSelect @bind-Value="@_vehicle">
                @foreach (vwVehicle vehicle in _vehicles)
                {
                    <MudSelectItem Value="vehicle.IdVehicle">@vehicle.Brand</MudSelectItem>
                }
            </MudSelect>

        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Submit">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    public vwWorkOrder model { get; set; } = new();

    private tClient _client { get; set; } = new();
    private List<tClient> _clients { get; set; } = [];

    private vwVehicle _vehicle { get; set; } = new();
    private List<vwVehicle> _vehicles { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        _clients = await DBAutoTrackContext.tClient.ToListAsync();
        _vehicles = await DBAutoTrackContext.vwVehicle.ToListAsync();
    }

    private void Submit() => MudDialog.Close(DialogResult.Ok(true));

    private void Cancel() => MudDialog.Cancel();
}
